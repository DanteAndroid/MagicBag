APP_NAME=MagicRAG
APP_VERSION=0.1.0
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Ensure this path exists in the runtime environment.
RAG_DOCUMENTS_DIR=/data/rag

QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=magic_knowledge
QDRANT_VECTOR_SIZE=1024

# The service accepts either DEEPSEEK_* or OPENAI_* env names.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_BATCH_SIZE=32

TOP_K=5
SCORE_THRESHOLD=0.45
CHUNK_SIZE=400
CHUNK_OVERLAP=60
